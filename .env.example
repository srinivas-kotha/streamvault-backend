# StreamVault Backend
NODE_ENV=development
PORT=3001

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_orchestration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# JWT
JWT_SECRET=generate_a_secure_jwt_secret_here
JWT_REFRESH_SECRET=generate_a_different_jwt_secret_here

# Xtream Codes IPTV Provider
XTREAM_HOST=your-iptv-provider-host
XTREAM_PORT=80
XTREAM_USERNAME=your-xtream-username
XTREAM_PASSWORD=your-xtream-password

# Downloads & DVR
DOWNLOAD_IDLE_START=02:00
DOWNLOAD_IDLE_END=06:00
MAX_STORAGE_GB=15

# Admin seed (only consumed by `npm run seed:admin`, never by the running API)
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change_me_before_running
